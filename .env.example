# Accounts & Billing — all optional. Without these, auth uses an ephemeral
# in-memory store (dev/demo only) and billing endpoints fail closed.

# Secret used to sign session cookies (HMAC-SHA256). REQUIRED for auth to work.
# Generate one, e.g.: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Upstash Redis REST endpoint — persistent user store. If unset, store is in-memory (ephemeral).
UPSTASH_REDIS_REST_URL=
# Upstash Redis REST token — must be set together with UPSTASH_REDIS_REST_URL.
UPSTASH_REDIS_REST_TOKEN=

# Stripe secret key (sk_live_... / sk_test_...). REQUIRED for checkout + customer creation.
STRIPE_SECRET_KEY=
# Stripe recurring Price ID for the Pro subscription (price_...). REQUIRED for checkout.
STRIPE_PRICE_ID=
# Stripe webhook signing secret (whsec_...). REQUIRED for /api/billing/webhook to accept events.
STRIPE_WEBHOOK_SECRET=

# Trusted public base URL (e.g. https://yourapp.com). Used for Stripe checkout
# success/cancel redirects so a spoofed Origin/Host can't redirect elsewhere.
# Falls back to the request origin if unset.
APP_URL=

# Optional. Comma-separated host suffixes the EA feed proxies (ah-feed / snipe-
# scan) may call. Defaults to "ea.com,easports.com". Set only if your captured
# auction endpoint lives on a different EA host. This is an SSRF allowlist —
# keep it to EA domains.
EA_HOST_ALLOWLIST=
